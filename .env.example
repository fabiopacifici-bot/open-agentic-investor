# Alpha Vantage API key (do NOT commit real keys)
ALPHA_API=<alpha-vantage-api-key>
# How many tickers to fetch per run
DAILY_TICKER_CAP=20
# Delay between requests (seconds)
ALPHA_DELAY_SECONDS=1.2
# Retry/backoff settings
ALPHA_MAX_RETRIES=3
ALPHA_BACKOFF_BASE=2
# Path to investments DB (optional)
INVEST_DB_PATH=~/Documents/Investments/portfolio.db
