# INVESTMENTS_DIR — base directory for portfolio DB and reports (default: ~/Documents/Investments)
INVESTMENTS_DIR=~/Documents/Investments

# INVESTMENTS_DB — full path to SQLite DB (default: $INVESTMENTS_DIR/portfolio.db)
INVESTMENTS_DB=~/Documents/Investments/portfolio.db

# WATCHER_CHAT_ID — Telegram chat id for alerts (default: 6395145098)
WATCHER_CHAT_ID=6395145098
